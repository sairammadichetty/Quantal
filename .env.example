# Copy to .env and adjust for local development.
# The defaults below match production; override only when needed.

# Application
APP_NAME="Orbital Copilot Usage API"
DEBUG=False

# External API (upstream Orbital services)
ORBITAL_BASE_URL="https://owpublic.blob.core.windows.net/tech-task"

# HTTP client tuning
ORBITAL_HTTP_TIMEOUT_SECONDS=10.0
