# Copy to .env and adjust for local development.
# The defaults below match production; override only when needed.

# Application
APP_NAME="Orbital Copilot Usage API"
DEBUG=False

# External API (upstream Orbital services)
ORBITAL_BASE_URL="https://owpublic.blob.core.windows.net/tech-task"

# Upstream route paths. Override ORBITAL_MESSAGES_PATH when you need to
# target a different billing period (e.g. "/messages/2025-Q1"). The report
# template MUST contain a {report_id} placeholder.
ORBITAL_MESSAGES_PATH="/messages/current-period"
ORBITAL_REPORT_PATH_TEMPLATE="/reports/{report_id}"

# HTTP client tuning
ORBITAL_HTTP_TIMEOUT_SECONDS=10.0
